# Copie ce fichier en .env et remplis les valeurs (le .env est gitignoré).

# --- API ---
PORT=3001
HOST=0.0.0.0
# Origine(s) autorisée(s) pour le navigateur (CORS), séparées par des virgules.
CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL (sur le NAS) ---
# Remplace MOT_DE_PASSE par le POSTGRES_PASSWORD défini dans infra/.env
DATABASE_URL=postgres://portfolio:MOT_DE_PASSE@192.168.1.XX:55432/portfolio

# --- ntfy (sur le NAS) ---
NTFY_URL=http://192.168.1.XX:8080
# Topic SECRET et difficile à deviner (= ta "protection"). Abonne-toi au même dans l'app ntfy.
NTFY_TOPIC=portfolio-contact-CHANGE-MOI-xxxx
