# Copie ce fichier en .env sur le NAS et remplis les valeurs.
# NE JAMAIS committer le vrai .env (il est gitignoré).

# --- PostgreSQL ---
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=remplace-par-un-mot-de-passe-fort
POSTGRES_DB=portfolio

# --- ntfy ---
# URL publique du serveur ntfy = IP du NAS + port mappé (8080).
# Sert à l'app ntfy du téléphone et aux liens cliquables dans les notifs.
NTFY_BASE_URL=http://192.168.1.XX:8080
# Topic secret du formulaire de contact (l'API publie dessus). Garder privé.
NTFY_TOPIC=portfolio-contact-xxxxxxxxxxxxxxxx

# --- API / Web (mise en ligne) ---
# Origine publique du site → autorisée par le CORS de l'API.
SITE_URL=https://alexiswallez.fr
# Port hôte exposé par Nginx (web), derrière le reverse proxy + HTTPS d'UGOS.
WEB_PORT=8088
