# Copie ce fichier en .env sur le NAS et remplis les valeurs.
# NE JAMAIS committer le vrai .env (il est gitignoré).

# --- PostgreSQL ---
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=remplace-par-un-mot-de-passe-fort
POSTGRES_DB=portfolio

# --- ntfy ---
# URL publique du serveur ntfy = IP du NAS + port mappé (8080).
# Sert à l'app ntfy du téléphone et aux liens cliquables dans les notifs.
NTFY_BASE_URL=http://192.168.1.XX:8080
# Topic secret du formulaire de contact (l'API publie dessus). Garder privé.
NTFY_TOPIC=portfolio-contact-xxxxxxxxxxxxxxxx
# Token de publication ntfy (auth activée) — généré par `ntfy token add <user>`.
NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anti-bot ---
# Secret Turnstile (Cloudflare) — vérifie le jeton du formulaire côté serveur.
# La Site Key (publique) est dans le front ; ce secret reste privé. Vide = vérif désactivée.
TURNSTILE_SECRET=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- API / Web (mise en ligne) ---
# Origine publique du site → autorisée par le CORS de l'API.
SITE_URL=https://alexiswallez.fr
# Port hôte exposé par Nginx (web), derrière le reverse proxy + HTTPS d'UGOS.
WEB_PORT=8088

# --- Outil admin / CRM interne (conteneur portfolio-admin, port 8100 LAN/VPN) ---
# User PostgreSQL dédié (droits limités). À créer UNE FOIS dans postgres :
#   docker compose exec postgres psql -U $POSTGRES_USER -d $POSTGRES_DB
#   puis exécuter le bloc SQL documenté (CREATE ROLE admin_app …).
ADMIN_DB_USER=admin_app
ADMIN_DB_PASSWORD=remplace-par-un-mot-de-passe-fort
# Hash bcrypt du mot de passe de connexion à l'outil.
# Générer : cd admin && npm run hash-password (les $ sont doublés exprès :
# docker compose interpolerait sinon les $ du hash).
ADMIN_PASSWORD_HASH=$$2b$$12$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret de signature des cookies de session (64 caractères aléatoires).
ADMIN_SESSION_SECRET=remplace-par-64-caracteres-aleatoires
