# Reverse proxy public + HTTPS automatique (Let's Encrypt).
# Caddy obtient et renouvelle le certificat tout seul, redirige 80→443,
# et proxy vers le conteneur `web` (Nginx) via le réseau Docker interne.
{
	# e-mail ACME : reçoit les avis d'expiration de certificat
	email wallezalexis@gmail.com
}

# www → domaine principal (canonique)
www.alexiswallez.fr {
	redir https://alexiswallez.fr{uri} permanent
}

alexiswallez.fr {
	# En-têtes de sécurité ajoutés à l'edge (HSTS + Permissions-Policy).
	# X-Frame-Options / X-Content-Type-Options / Referrer-Policy sont déjà posés
	# par Nginx (web) et traversent Caddy. CSP volontairement omise (script anti-flash inline).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=()"
		-Server
	}
	# Nginx (web) compresse déjà en gzip. On fait simplement TRAVERSER sa réponse :
	# `compression off` désactive la décompression automatique du transport Go de
	# Caddy, et on demande explicitement du gzip à l'upstream. Le navigateur reçoit
	# donc bien du gzip (le `encode` de Caddy, lui, ne re-compressait pas la sortie
	# du reverse_proxy dans cette version).
	reverse_proxy web:80 {
		header_up Accept-Encoding gzip
		transport http {
			compression off
		}
	}
}
